# .bash_profile

# Get the aliases and functions
if [ -f ~/.bashrc ]; then
	. ~/.bashrc
fi

# User specific environment and startup programs

PATH=$PATH:$HOME/bin

export PATH

. "$HOME/.local/bin/env"

# Capture the Kerberos principal from the ticket we logged in with,
# which sets KRB5_PRINCIPAL.
source "$HOME/bin/get_krb_principal.sh"

# Use that principal to configure the git/github environment
# (user.name/email, GIT_SSH_COMMAND -> id_<user>_rsa, ssh-add).
source "$HOME/bin/set_git_env.sh"

# Only now that the git/github environment is fully set up do we
# destroy the kerberos ticket, so we fall back to the group keytab.
kdestroy

# With the login ticket gone, obtain a fresh ticket for the current
# DAQ group account from its deployed keytab (kinit via the script).
source "$HOME/bin/get_krb_daq_principle.sh"
