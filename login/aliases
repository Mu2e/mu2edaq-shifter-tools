# .aliases
#
# Shell aliases for the Mu2e DAQ shifter accounts.
# Sourced from .bashrc

alias ll='ls -l --color=auto'
alias l='ll'
alias rgrep='grep -R'
alias ccgrep="grep -R --include='*.cc'"
alias hgrep="grep -R --include='*.h'"
alias srcgrep="grep -R --include='*.cc' --include='*.h'"
alias less='less -S' #no word wrap
alias sshx='ssh-selector -c ~/config/mu2e_daq.yaml'
alias nodes='ssh-selector -c ~/config/mu2e_daq.yaml'

